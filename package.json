{
  "name": "journal",
  "version": "4.0.0",
  "description": "A self-hosted website to show your photographs",
  "private": true,
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:sw\" \"node server.js\"",
    "build": "npm run build:sw && next build",
    "build:sw": "NODE_ENV=production node scripts/build/serviceworker.mjs",
    "dev:sw": "WATCH=true node scripts/build/serviceworker.mjs",
    "start": "node .next/standalone/server.js",
    "preview": "next start",
    "start:express": "NODE_ENV=production COMPRESSION=enabled node server.js",
    "lint": "eslint .",
    "lint:write": "eslint . --fix",
    "prettier": "prettier --write \"./src/**/*.js\"",
    "test": "npm run test:web && npm run test:node",
    "test:web": "jest --coverage --passWithNoTests --verbose --config jest.config.js",
    "test:node": "jest --coverage --passWithNoTests --verbose --config jest.node.config.js",
    "sb": "storybook dev -p 6006",
    "db:reset": "babel-node scripts/db/reset.js",
    "db:seed": "babel-node scripts/db/seed.js",
    "prepare": "husky",
    "build-storybook": "storybook build",
    "e2e": "cypress open"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claireso/journal.git"
  },
  "author": "Claire Sosset",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/claireso/journal/issues"
  },
  "homepage": "https://github.com/claireso/journal#readme",
  "dependencies": {
    "@heroicons/react": "2.2.0",
    "@vanilla-extract/css": "1.20.1",
    "@vanilla-extract/recipes": "0.5.7",
    "better-auth": "1.6.2",
    "colorthief": "3.3.1",
    "date-fns": "4.1.0",
    "lodash": "4.18.1",
    "next": "16.2.3",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "0.34.5",
    "ulid": "3.0.2",
    "web-push": "3.6.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/node": "7.29.0",
    "@changesets/cli": "2.30.0",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-links": "10.3.5",
    "@storybook/addon-webpack5-compiler-swc": "4.0.3",
    "@storybook/react-webpack5": "10.3.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "@vanilla-extract/jest-transform": "1.1.22",
    "@vanilla-extract/next-plugin": "2.5.2",
    "@vanilla-extract/webpack-plugin": "2.3.27",
    "@vitest/mocker": "4.1.4",
    "babel-loader": "10.1.1",
    "babel-plugin-module-resolver": "5.0.3",
    "babel-plugin-react-remove-properties": "0.3.1",
    "concurrently": "9.2.1",
    "cypress": "9.5.4",
    "cypress-file-upload": "5.0.8",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-storybook": "10.3.5",
    "express": "4.21.2",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "lint-staged": "16.4.0",
    "mini-css-extract-plugin": "2.10.2",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.2",
    "react-test-renderer": "19.2.5",
    "storybook": "10.3.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  }
}
